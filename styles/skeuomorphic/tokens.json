{
  "colors": {
    "bg": "#C8C8C8",
    "fg": "#1A1A1A",
    "accent": "#4A90E2",
    "surface-top": "#F4F4F4",
    "surface-bottom": "#D0D0D0"
  },
  "radius": { "sm": "6px", "md": "10px", "lg": "14px" },
  "shadow": {
    "bevel": "inset 0 1px 0 rgba(255,255,255,0.7), inset 0 -1px 0 rgba(0,0,0,0.2), 0 2px 4px rgba(0,0,0,0.25)",
    "pressed": "inset 0 1px 3px rgba(0,0,0,0.35)"
  },
  "gradients": {
    "button": "linear-gradient(180deg, #F4F4F4 0%, #D0D0D0 100%)",
    "pressed": "linear-gradient(180deg, #BFBFBF 0%, #D5D5D5 100%)"
  },
  "font": {
    "sans": "'Lucida Grande', 'Helvetica Neue', sans-serif"
  },
  "spacing_scale": "4px"
}
