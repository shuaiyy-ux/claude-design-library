{
  "colors": {
    "bg": "#FFFBF0",
    "fg": "#0A0A0A",
    "accent": "#B5EAD7",
    "accent-alt": "#FFB5A7",
    "accent-3": "#B5B5FF",
    "accent-4": "#FFE066"
  },
  "radius": { "sm": "4px", "md": "8px", "lg": "12px", "full": "9999px" },
