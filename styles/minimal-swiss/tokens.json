{
  "colors": {
    "bg": "#FFFFFF",
    "fg": "#0A0A0A",
    "accent": "#E63946",
    "muted": "#6B6B6B"
  },
  "radius": { "sm": "0px", "md": "0px", "lg": "0px" },
  "border": { "width": "1px", "color": "#0A0A0A", "style": "solid" },
  "shadow": { "none": "none" },
  "font": {
    "sans": "'Inter', 'Helvetica Neue', Arial, sans-serif",
    "display": "'Inter', 'Neue Haas Grotesk', sans-serif"
  },
  "type_scale": {
    "display": "clamp(48px, 8vw, 96px)",
