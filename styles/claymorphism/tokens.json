{
  "colors": {
    "bg": "#E0E5EC",
    "fg": "#4A4E69",
    "accent": "#A084E8",
    "accent-alt": "#FFB5A7"
  },
  "radius": { "sm": "16px", "md": "24px", "lg": "32px", "full": "9999px" },
  "shadow": {
    "clay": "inset 8px 8px 16px rgba(255,255,255,0.9), inset -8px -8px 16px rgba(163,177,198,0.6), 8px 8px 24px rgba(163,177,198,0.5)",
    "clay-pressed": "inset 4px 4px 8px rgba(163,177,198,0.6), inset -4px -4px 8px rgba(255,255,255,0.9)"
  },
  "font": {
    "sans": "'Nunito', 'Quicksand', sans-serif"
  },
  "spacing_scale": "8px",
  "motion": { "duration": "200ms", "easing": "ease-out" }
}
