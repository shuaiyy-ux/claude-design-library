{
  "colors": {
    "bg": "#0C0C0C",
    "fg": "#33FF33",
    "accent": "#FFB000",
    "muted": "#1E5F1E"
  },
  "radius": { "sm": "0px", "md": "0px", "lg": "0px" },
  "shadow": { "glow": "0 0 6px currentColor" },
  "font": {
    "mono": "'VT323', 'IBM Plex Mono', 'Courier New', monospace"
  },
  "effects": {
    "scanlines": "repeating-linear-gradient(0deg, rgba(0,0,0,0.2) 0px, rgba(0,0,0,0.2) 1px, transparent 1px, transparent 3px)"
  },
  "spacing_scale": "4px",
  "motion": { "cursor_blink": "1s step-end infinite" }
}
