{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "claude-design-library entry",
  "type": "object",
  "required": ["name", "slug", "type", "tags", "license", "added"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "type": { "enum": ["style", "design-system", "template", "inspiration", "icon-set", "font", "awesome-list", "animation", "photo-source"] },
    "tags": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "tech": { "type": "array", "items": { "type": "string" } },
    "source_url": { "type": "string", "format": "uri" },
    "license": {
      "enum": ["MIT", "Apache-2.0", "BSD-3-Clause", "CC-BY-4.0", "CC0", "CC0-1.0", "ISC", "OFL-1.1", "reference-only"]
    },
    "preview": { "type": "string" },
    "preview_url": { "type": "string", "format": "uri" },
    "claude_prompt": { "type": "string" },
    "added": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  }
}
